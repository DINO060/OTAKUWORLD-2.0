# Supabase Configuration
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional - for production
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Tenor (GIF picker in live chat)
# Get a free key at https://developers.google.com/tenor/guides/quickstart
VITE_TENOR_API_KEY=

# Catalogue / Discover APIs
# TMDB (Films & Series) — free at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=
# Last.fm (Music) — free at https://www.last.fm/api/account/create
VITE_LASTFM_API_KEY=
# RAWG (Games) — free at https://rawg.io/apidocs
VITE_RAWG_API_KEY=
